# AI 测试用例生成系统 — 环境变量模板
#
# 使用方法：复制本文件为 .env，填入你的 API Key
#   cp .env.example .env
#
# ⚠️ .env 文件不要提交到 Git（已在 .gitignore 中）
#
# 🔒 生产环境密钥管理建议：
#   不要将明文密钥直接写入 .env 文件长期保存。
#   生产部署推荐使用 Docker Secrets 或外部密钥管理服务（如 HashiCorp Vault）。
#   Docker Secrets 示例：
#     1. echo "sk-your-api-key" | docker secret create llm_api_key -
#     2. docker-compose.yml 中通过 secrets 挂载到 /run/secrets/llm_api_key
#     3. 应用侧从文件读取：open("/run/secrets/llm_api_key").read().strip()

# ─── LLM API Key（必填一个）──────────────────────────
# DeepSeek
LLM_API_KEY=sk-your-api-key-here

# ─── LLM 配置（可选，覆盖 config.yaml 默认值）─────────
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ─── Obsidian Local REST API（可选）───────────────────
# 用于加速知识库搜索。安装 Obsidian Local REST API 插件后在插件设置中查看
# OBSIDIAN_API_KEY=
# OBSIDIAN_API_BASE=http://localhost:27123

# ─── 测试管理平台（可选）────────────────────────────
# TESTRAIL_API_KEY=

# ─── 认证密钥（生产环境必填）────────────────────────
# JWT 签名密钥，必须 >=32 字符的随机字符串。
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(48))"
# ⚠️ 生产环境（AI_TEST_ENV=production）未配置或为弱密钥会拒绝启动！
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars

# ─── 鉴权模式开关 ──────────────────────────────────────
# false（默认）：本地工具模式，所有 API 无需 JWT token，前端无登录页。
#               适用于纯本地部署（像 Hermes），EventSource SSE 也能直连。
# true：        恢复完整 JWT 校验，所有 /api/* 需 Bearer token。
AUTH_ENABLED=false

# ─── 运行环境（可选）──────────────────────────────────
# production: 启用生产模式（强制安全密钥、隐藏错误详情）
# development: 开发模式（宽松校验、显示详细错误）
# AI_TEST_ENV=development

# ─── 管理员账户（生产环境必填）────────────────────────
# 首次启动时自动创建管理员账户。
# 未配置 ADMIN_PASSWORD 时，系统会生成随机密码并打印到日志（需立即查日志获取并修改）。
# 生产环境务必通过环境变量注入固定密码，避免查日志获取随机密码的麻烦。
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# ─── Webhook 签名密钥（如使用 webhook 功能则必填）──────
# 用于验证外部系统回调请求的 HMAC-SHA256 签名。
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
# 外部系统需用相同的密钥计算 HMAC-SHA256(body, secret) 并放入 X-Webhook-Signature 头。
# 未配置时所有 webhook 请求将被拒绝（安全默认）。
# WEBHOOK_SECRET=
