# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Local state
_meta.json

# Node / Vue frontend
node_modules/
webui/node_modules/

# Vue 前端构建产物（由 `npm run build` 生成，不入版本库）
web/static/dist/

# Runtime output (do not commit)
output/
test-run/

# Runtime data (do not commit)
data/

# Test & coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Runtime uploads (keep dir, ignore files)
uploads/*
!uploads/.gitkeep
web/uploads/*
!web/uploads/.gitkeep

# Environment files (contain API keys)
.env

# 业务文档暂存（防止误提交真实业务资产）
# 忽略所有 .docx / .xlsx，但保留 demo_ 前缀的示例文件
*.docx
*.xlsx
!demo_*.docx
!demo_*.xlsx
# 保留 examples/ 和特定示例目录下的文件
!examples/**
!**/demo_*

# CodeGraph index cache
.codegraph/

