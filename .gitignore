# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Local state
_meta.json

# Runtime output (do not commit)
output/
test-run/

# Runtime data (do not commit)
data/

# Test & coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
# Playwright e2e 产物
webui/playwright-report/
webui/test-results/

# Runtime uploads (keep dir, ignore files)
uploads/*
!uploads/.gitkeep
web/uploads/*
!web/uploads/.gitkeep

# Environment files (contain API keys)
.env
# 本地 LLM 配置（含明文 API key，不入库）
config.zai.yaml
config.*.local.yaml

# Hermes 桌面应用工作目录（附件/计划，与项目无关）
.hermes/

# 业务文档暂存（防止误提交真实业务资产）
# 忽略所有 .docx / .xlsx，但保留 demo_ 前缀的示例文件
*.docx
*.xlsx
!demo_*.docx
!demo_*.xlsx
# 保留 examples/ 和特定示例目录下的文件
!examples/**
!**/demo_*

# IDE / Trae 内部目录
.trae/

# 散落在根目录的临时测试文件
/test_requirement.md

# CodeGraph index cache
.codegraph/

.meituan-catpaw/

# 清理技术产物（日志与隔离区，集中管理，不入库）
logs/

# 无人值守清理隔离区（历史兼容，已废弃改用 logs/cleanup-quarantine-*/）
.cleanup-quarantine-*/
